@{
    ViewData["Title"] = "Create Customer";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <span class="home-kicker">
                    Employee Reservation Management
                </span>

                <h1 class="page-title">
                    Create New Customer
                </h1>

                <p class="page-subtitle mb-0">
                    Create a customer account before continuing with the walk-in reservation.
                </p>
            </div>

            <a asp-controller="Reservation"
               asp-action="WalkIn"
               class="btn btn-outline-secondary">
                Back to Customer Search
            </a>
        </div>
    </div>
</section>

<div class="row justify-content-center mb-5">
    <div class="col-lg-8">
        <section class="card">
            <div class="card-header">
                <h2 class="h5 mb-1">
                    Customer Information
                </h2>

                <p class="mb-0 text-muted">
                    Enter the customer's contact information and create a temporary password.
                </p>
            </div>

            <div class="card-body">
                <form asp-controller="Reservation"
                      asp-action="CreateCustomer"
                      method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="firstName"
                                   class="form-label">
                                First Name
                            </label>

                            <input id="firstName"
                                   name="firstName"
                                   type="text"
                                   class="form-control"
                                   value="@ViewBag.FirstName"
                                   placeholder="Enter first name"
                                   required />

                            <span class="text-danger">
                                @Html.ValidationMessage("firstName")
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label for="lastName"
                                   class="form-label">
                                Last Name
                            </label>

                            <input id="lastName"
                                   name="lastName"
                                   type="text"
                                   class="form-control"
                                   value="@ViewBag.LastName"
                                   placeholder="Enter last name"
                                   required />

                            <span class="text-danger">
                                @Html.ValidationMessage("lastName")
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label for="email"
                                   class="form-label">
                                Email Address
                            </label>

                            <input id="email"
                                   name="email"
                                   type="email"
                                   class="form-control"
                                   value="@ViewBag.Email"
                                   placeholder="customer@example.com"
                                   required />

                            <span class="text-danger">
                                @Html.ValidationMessage("email")
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label for="phoneNumber"
                                   class="form-label">
                                Phone Number
                            </label>

                            <input id="phoneNumber"
                                   name="phoneNumber"
                                   type="tel"
                                   class="form-control"
                                   value="@ViewBag.PhoneNumber"
                                   placeholder="801-555-1234"
                                   required />

                            <span class="text-danger">
                                @Html.ValidationMessage("phoneNumber")
                            </span>
                        </div>

                        <div class="col-12">
                            <label for="password"
                                   class="form-label">
                                Temporary Password
                            </label>

                            <input id="password"
                                   name="password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Enter a temporary password"
                                   required />

                            <span class="text-danger">
                                @Html.ValidationMessage("password")
                            </span>

                            <div class="form-text">
                                Give this temporary password to the customer so they can use the account.
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit"
                                class="btn btn-primary">
                            Create Customer
                        </button>

                        <a asp-controller="Reservation"
                           asp-action="WalkIn"
                           class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </section>
    </div>
</div>