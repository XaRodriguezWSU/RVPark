@model IEnumerable<RVSite.Models.Reservation>

    @{
    ViewData["Title"] = "Reservations";
    }

    <section class="card admin-hero mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <span class="home-kicker">Reservation Management</span>
                    <h1 class="page-title">Reservations</h1>
                    <p class="page-subtitle">
                        Review, edit, cancel, and search current reservation records.
                    </p>
                </div>

                <a class="btn btn-primary"
                   asp-controller="Reservation"
                   asp-action="Search">
                    Search Reservations
                </a>
            </div>
        </div>
    </section>

    <section class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="h5 mb-1">Reservation Records</h2>
                <p class="mb-0 text-muted">@Model.Count() total reservations</p>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle admin-table mb-0">
                    <thead>
                        <tr>
                            <th>Reservation ID</th>
                            <th>Customer</th>
                            <th>Site</th>
                            <th>Check-In</th>
                            <th>Check-Out</th>
                            <th class="text-end">Total Cost</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-bold">@r.ReservationID</td>
                            <td>@(r.User != null ? $"{r.User.FirstName} {r.User.LastName}" : "Unknown")</td>
                            <td>@(r.Site != null ? r.Site.SiteNumber : "Unknown")</td>
                            <td>@r.CheckInDate.ToShortDateString()</td>
                            <td>@r.CheckOutDate.ToShortDateString()</td>
                            <td class="text-end">@r.TotalCost.ToString("C")</td>
                            <td>
                                <span class="badge bg-secondary">@r.ReservationStatus</span>
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a class="btn btn-outline-primary"
                                       asp-controller="Reservation"
                                       asp-action="Edit"
                                       asp-route-id="@r.ReservationID">
                                        Edit
                                    </a>

                                    <a class="btn btn-outline-danger"
                                       asp-controller="Reservation"
                                       asp-action="CancelReservation"
                                       asp-route-id="@r.ReservationID">
                                        Cancel
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
