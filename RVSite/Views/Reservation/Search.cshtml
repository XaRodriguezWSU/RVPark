@{
    ViewData["Title"] = "Search Reservations";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <span class="home-kicker">Reservation Management</span>
        <h1 class="page-title">Search Reservations</h1>
        <p class="page-subtitle">
            Find reservations by reservation number or customer name.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2 class="h5 mb-0">Search Criteria</h2>
    </div>

    <div class="card-body">
        <form asp-action="Search" method="post">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label">Reservation Number</label>
                    <input type="text"
                           name="reservationNumber"
                           class="form-control"
                           placeholder="Example: 1024" />
                </div>

                <div class="col-md-5">
                    <label class="form-label">Customer Name</label>
                    <input type="text"
                           name="customerName"
                           class="form-control"
                           placeholder="Example: John Doe" />
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        Search
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>