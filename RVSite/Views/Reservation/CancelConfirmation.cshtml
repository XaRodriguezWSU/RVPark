@{
}
@model RVSite.Models.Reservation

@{
    ViewData["Title"] = "Reservation Cancelled";
}

<h2>Reservation Cancelled</h2>

<div class="alert alert-warning">
    This reservation has been marked as <strong>Cancelled</strong>.
</div>

<p><strong>Reservation ID:</strong> @Model.ReservationID</p>
<p><strong>Customer:</strong> @Model.User.FirstName @Model.User.LastName</p>
<p><strong>Site:</strong> @Model.Site.SiteNumber</p>
<p><strong>Original Check-In:</strong> @Model.CheckInDate.ToShortDateString()</p>
<p><strong>Original Check-Out:</strong> @Model.CheckOutDate.ToShortDateString()</p>

<a class="btn btn-primary" asp-controller="Reservation" asp-action="Index">Back to Reservations</a>
