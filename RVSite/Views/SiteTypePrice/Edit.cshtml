@{
}

@model RVSite.Models.SiteTypePrice

<h2>Edit Price Range</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="SiteTypePriceID" />
    <input type="hidden" asp-for="SiteTypeID" />

    <div class="form-group">
        <label>Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>End Date (optional)</label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Price</label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <button class="btn btn-success mt-3">Save Changes</button>
    <a asp-action="Index" asp-route-siteTypeId="@Model.SiteTypeID" class="btn btn-secondary mt-3">Cancel</a>
</form>