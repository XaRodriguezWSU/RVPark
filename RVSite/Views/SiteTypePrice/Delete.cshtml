@{
}

@model RVSite.Models.SiteTypePrice

<h2>Delete Price Range</h2>

<div class="alert alert-warning">
    <p>Are you sure you want to delete this price range?</p>
</div>

<table class="table">
    <tr>
        <th>Start Date</th>
        <td>@Model.StartDate.ToShortDateString()</td>
    </tr>
    <tr>
        <th>End Date</th>
        <td>@(Model.EndDate?.ToShortDateString() ?? "Current")</td>
    </tr>
    <tr>
        <th>Price</th>
        <td>@Model.Price</td>
    </tr>
</table>

<form asp-action="Delete">
    <input type="hidden" asp-for="SiteTypePriceID" />
    <input type="hidden" asp-for="SiteTypeID" />

    <button class="btn btn-danger">Delete</button>
    <a asp-action="Index" asp-route-siteTypeId="@Model.SiteTypeID" class="btn btn-secondary">Cancel</a>
</form>