@using RVSite.Models

@{
    ViewData["Title"] = "Admin Dashboard";
    var recentSites = ViewBag.RecentSites as List<Site>;
}

<div class="admin-dashboard">

    <section class="admin-hero card mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <span class="home-kicker">Administration</span>
                    <h1 class="page-title">Admin Dashboard</h1>
                    <p class="page-subtitle">
                        Manage site availability, site editing, reservations, fees, and photo management.
                    </p>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2">
                    <a asp-controller="Reservation" asp-action="Search" class="btn btn-primary">
                        Search Reservations
                    </a>

                    <a asp-controller="Admin" asp-action="Reports" class="btn btn-outline-secondary">
                        Generate Reports
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="row g-3 mb-4">

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card">
                <div class="card-body">
                    <span>Total Sites</span>
                    <strong>@ViewBag.TotalSites</strong>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card">
                <div class="card-body">
                    <span>Available Sites</span>
                    <strong class="text-success">@ViewBag.AvailableSites</strong>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card">
                <div class="card-body">
                    <span>Reserved Sites</span>
                    <strong class="text-warning">@ViewBag.ReservedSites</strong>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card">
                <div class="card-body">
                    <span>Maintenance Tasks</span>
                    <strong class="text-danger">@ViewBag.MaintenanceSites</strong>
                </div>
            </div>
        </div>

    </section>

    <section class="row g-4">

        <div class="col-xl-8">
            <div class="card admin-table-card h-100">
                <div class="card-header d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2">
                    <div>
                        <h2 class="h5 mb-1">Site Overview</h2>
                        <p class="mb-0 text-muted">Recent site records and current operating status.</p>
                    </div>

                    <a asp-controller="Sites" asp-action="Index" class="btn btn-sm btn-outline-primary">
                        Manage All Sites
                    </a>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle admin-table">
                            <thead>
                                <tr>
                                    <th>Site Number</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Max RV Length</th>
                                    <th>Base Rate</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (recentSites != null && recentSites.Any())
                                {
                                    foreach (var site in recentSites)
                                    {
                                <tr>
                                    <td class="fw-bold">@site.SiteNumber</td>
                                    <td>@site.SiteType?.Name</td>
                                    <td>
                                        @if (site.SiteStatus == SiteStatus.Available.ToString())
                                                {
                                        <span class="badge bg-success">Available</span>
                                                }
                                                else if (site.SiteStatus == SiteStatus.Reserved.ToString())
                                                {
                                        <span class="badge bg-warning text-dark">Reserved</span>
                                                }
                                                else if (site.SiteStatus == SiteStatus.Maintenance.ToString())
                                                {
                                        <span class="badge bg-danger">Maintenance</span>
                                                }
                                                else
                                                {
                                        <span class="badge bg-secondary">@site.SiteStatus</span>
                                                }
                                    </td>
                                    <td>@site.MaxRVLength ft</td>
                                    <td>@site.BaseRate.ToString("C")</td>
                                    <td class="text-end">
                                        <a asp-controller="Sites"
                                           asp-action="Edit"
                                           asp-route-id="@site.SiteID"
                                           class="btn btn-sm btn-outline-secondary">
                                            Edit
                                        </a>
                                    </td>
                                </tr>
                                    }
                                }
                                else
                                {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        No sites found.
                                    </td>
                                </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h2 class="h5 mb-0">Quick Actions</h2>
                </div>

                <div class="card-body d-grid gap-2">
                    <a asp-controller="Sites" asp-action="Index" class="btn btn-primary">
                        Manage Sites
                    </a>

                    <a asp-controller="Sites" asp-action="Create" class="btn btn-outline-primary">
                        Add New Site
                    </a>

                    <a asp-controller="Reservation" asp-action="Index" class="btn btn-outline-secondary">
                        Edit Reservations
                    </a>

                    <a asp-controller="Admin" asp-action="Employees" class="btn btn-outline-secondary">
                        Manage Employees
                    </a>

                    <a asp-controller="Fees" asp-action="Index" class="btn btn-outline-secondary">
                        Manage Fees
                    </a>
                </div>
            </div>

            <div class="card photo-action-card">
                <div class="card-body">
                    <span class="home-kicker">Media</span>
                    <h2 class="h5 mb-2">Photo Management</h2>
                    <p class="text-muted">
                        Preview, add, or update photos for each RV site from one central page.
                    </p>

                    <a asp-controller="SitePhoto" asp-action="Manage" class="btn btn-outline-primary w-100">
                        Manage Site Photos
                    </a>
                </div>
            </div>
        </div>

    </section>

</div>