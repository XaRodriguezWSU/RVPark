@model RVSite.Models.ReportsViewModel

@{
    ViewData["Title"] = "Reports Dashboard";
}

@* Report filter controls *@
<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form method="get" asp-controller="Admin" asp-action="Reports" class="border rounded p-4 mb-4">
    <h4 class="text-center mb-4">Filters</h4>

    <input type="hidden" name="reportType" value="@Model.ReportType" />

    <div class="row align-items-end">
        <div class="col-md-4">
            <label class="form-label">Start date</label>
            <input type="date" name="startDate" class="form-control" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
        </div>

        <div class="col-md-4">
            <label class="form-label">End date</label>
            <input type="date" name="endDate" class="form-control" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
        </div>

        <div class="col-md-4">
            <button type="submit" class="btn btn-success w-100">
                Generate Report
            </button>
        </div>
    </div>
</form>

@* Report Type Selection *@
<div class="btn-group w-100 mb-4" role="group" aria-label="Report Type">
    <a class="btn @(Model.ReportType == "Arrivals" ? "btn-secondary" : "btn-outline-secondary")"
       asp-action="Reports"
       asp-route-reportType="Arrivals"
       asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
       asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
        Daily Arrivals
    </a>

    <a class="btn @(Model.ReportType == "Departures" ? "btn-secondary" : "btn-outline-secondary")"
       asp-action="Reports"
       asp-route-reportType="Departures"
       asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
       asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
        Upcoming Departures
    </a>

    <a class="btn @(Model.ReportType == "Occupancy" ? "btn-secondary" : "btn-outline-secondary")"
       asp-action="Reports"
       asp-route-reportType="Occupancy"
       asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
       asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
        Occupancy
    </a>

    <a class="btn @(Model.ReportType == "Reservations" ? "btn-secondary" : "btn-outline-secondary")"
       asp-action="Reports"
       asp-route-reportType="Reservations"
       asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
       asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
        Reservation History
    </a>

    <a class="btn @(Model.ReportType == "Revenue" ? "btn-secondary" : "btn-outline-secondary")"
       asp-action="Reports"
       asp-route-reportType="Revenue"
       asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
       asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
        Revenue / Payments
    </a>
</div>

@* Dashboard Summary cards *@
<div class="border rounded p-4 mb-4">
    <h4 class="text-center mb-4">Report Summary</h4>

    <div class="row text-center">
        <div class="col-md-3 border rounded p-3">
            <h2>@Model.ArrivalsCount</h2>
            <p class="mb-0">Arrivals</p>
        </div>

        <div class="col-md-3 border rounded p-3">
            <h2>@Model.DeparturesCount</h2>
            <p class="mb-0">Departures</p>
        </div>

        <div class="col-md-3 border rounded p-3">
            <h2>@Model.OccupancyRate%</h2>
            <p class="mb-0">Occupancy</p>
        </div>

        <div class="col-md-3 border rounded p-3">
            <h2>@Model.RevenueTotal.ToString("C")</h2>
            <p class="mb-0">Revenue</p>
        </div>
    </div>

    @* Report Results table *@
    <p>
    Showing <strong>@Model.Reservations.Count</strong> records for
    <strong>@Model.ReportType</strong>.
    </p>

    <div class="mt-4 p-4 border rounded text-center text-muted">
        <h4 class="mb-3">@Model.ReportType Report Results</h4>
        @* If there are no results, display a message for the user *@
        @if (!Model.Reservations.Any())
        {
            <div class="alert alert-info">
                No reservations were found for the selected date range.
            </div>
        }
        else
        {
            //
            @if (Model.ReportType == "Arrivals")
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Guest</th>
                            <th>Site</th>
                            <th>Arrival Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Reservations)
                        {
                            <tr>
                                <td>@r.User?.FirstName @r.User?.LastName</td>
                                <td>@r.Site?.SiteNumber</td>
                                <td>@r.CheckInDate.ToShortDateString()</td>
                                <td>@r.ReservationStatus</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (Model.ReportType == "Departures")
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Guest</th>
                            <th>Site</th>
                            <th>Departure Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Reservations)
                        {
                            <tr>
                                <td>@r.User?.FirstName @r.User?.LastName</td>
                                <td>@r.Site?.SiteNumber</td>
                                <td>@r.CheckOutDate.ToShortDateString()</td>
                                <td>@r.ReservationStatus</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (Model.ReportType == "Revenue")
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Reservation ID</th>
                            <th>Guest</th>
                            <th>Total Cost</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Reservations)
                        {
                            <tr>
                                <td>@r.ReservationID</td>
                                <td>@r.User?.FirstName @r.User?.LastName</td>
                                <td>@r.TotalCost.ToString("C")</td>
                                <td>@r.ReservationStatus</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                @* Display reservation details in table format for selected report *@
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Reservation ID</th>
                        <th>Guest</th>
                        <th>Site</th>
                        <th>Check-In</th>
                        <th>Check-Out</th>
                        <th>Status</th>
                        <th>Total Cost</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reservation in Model.Reservations)
                    {
                        <tr>
                            <td>@reservation.ReservationID</td>
                            <td>@reservation.User?.FirstName @reservation.User?.LastName</td>
                            <td>@reservation.Site?.SiteNumber</td>
                            <td>@reservation.CheckInDate.ToShortDateString()</td>
                            <td>@reservation.CheckOutDate.ToShortDateString()</td>
                            <td>@reservation.ReservationStatus</td>
                            <td>@reservation.TotalCost.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
            }
            
        }
        
    </div>
</div>
