@model RVSite.Models.ReportsViewModel

@{
    ViewData["Title"] = "Reports Dashboard";
}

<div class="reports-page">

    <section class="card admin-hero mb-4">
        <div class="card-body p-4 p-lg-5">
            <span class="home-kicker">Administration</span>
            <h1 class="page-title">Reports Dashboard</h1>
            <p class="page-subtitle">
                Generate arrivals, departures, occupancy, site usage, reservation history, and revenue reports.
            </p>
        </div>
    </section>

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <section class="card mb-4">
        <div class="card-header">
            <h2 class="h5 mb-0">Report Filters</h2>
        </div>

        <div class="card-body">
            <form method="get" asp-controller="Admin" asp-action="Reports">
                <input type="hidden" name="reportType" value="@Model.ReportType" />

                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Start Date</label>
                        <input type="date"
                               name="startDate"
                               class="form-control"
                               value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">End Date</label>
                        <input type="date"
                               name="endDate"
                               class="form-control"
                               value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">
                            Generate Report
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <section class="row g-2 mb-4">
        <div class="col-md">
            <a class="btn w-100 @(Model.ReportType == "Arrivals" ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Reports"
               asp-route-reportType="Arrivals"
               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
                Daily Arrivals
            </a>
        </div>

        <div class="col-md">
            <a class="btn w-100 @(Model.ReportType == "Departures" ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Reports"
               asp-route-reportType="Departures"
               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
                Upcoming Departures
            </a>
        </div>

        <div class="col-md">
            <a class="btn w-100 @(Model.ReportType == "Occupancy" ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Reports"
               asp-route-reportType="Occupancy"
               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
                Occupancy
            </a>
        </div>

        <div class="col-md">
            <a class="btn w-100 @(Model.ReportType == "SiteUsage" ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Reports"
               asp-route-reportType="SiteUsage"
               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
                Site Usage
            </a>
        </div>

        <div class="col-md">
            <a class="btn w-100 @(Model.ReportType == "Reservations" ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Reports"
               asp-route-reportType="Reservations"
               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
                Reservation History
            </a>
        </div>

        <div class="col-md">
            <a class="btn w-100 @(Model.ReportType == "Revenue" ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Reports"
               asp-route-reportType="Revenue"
               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")">
                Revenue / Payments
            </a>
        </div>
    </section>

    <section class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card">
                <div class="card-body">
                    <span>Arrivals</span>
                    <strong>@Model.ArrivalsCount</strong>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card">
                <div class="card-body">
                    <span>Departures</span>
                    <strong>@Model.DeparturesCount</strong>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card">
                <div class="card-body">
                    <span>Occupancy</span>
                    <strong>@Model.OccupancyRate%</strong>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card">
                <div class="card-body">
                    <span>Revenue</span>
                    <strong>@Model.RevenueTotal.ToString("C")</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="card">
        <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
            <div>
                <h2 class="h5 mb-1">@Model.ReportType Report Results</h2>
                <p class="mb-0 text-muted">
                    Showing <strong>@Model.Reservations.Count</strong> records from
                    @Model.StartDate.ToShortDateString() to @Model.EndDate.ToShortDateString().
                </p>
            </div>

            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.print()">
                Print
            </button>
        </div>

        <div class="card-body p-0">
            @if (!Model.Reservations.Any())
            {
            <div class="p-4">
                <div class="alert alert-info mb-0">
                    No reservations were found for the selected date range.
                </div>
            </div>
            }
            else if (Model.ReportType == "Arrivals")
            {
            <div class="table-responsive">
                <table class="table table-hover align-middle admin-table">
                    <thead>
                        <tr>
                            <th>Guest</th>
                            <th>Site</th>
                            <th>Arrival Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Reservations)
                            {
                        <tr>
                            <td>@r.User?.FirstName @r.User?.LastName</td>
                            <td>@r.Site?.SiteNumber</td>
                            <td>@r.CheckInDate.ToShortDateString()</td>
                            <td>@r.ReservationStatus</td>
                        </tr>
                            }
                    </tbody>
                </table>
            </div>
            }
            else if (Model.ReportType == "Departures")
            {
            <div class="table-responsive">
                <table class="table table-hover align-middle admin-table">
                    <thead>
                        <tr>
                            <th>Guest</th>
                            <th>Site</th>
                            <th>Departure Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Reservations)
                            {
                        <tr>
                            <td>@r.User?.FirstName @r.User?.LastName</td>
                            <td>@r.Site?.SiteNumber</td>
                            <td>@r.CheckOutDate.ToShortDateString()</td>
                            <td>@r.ReservationStatus</td>
                        </tr>
                            }
                    </tbody>
                </table>
            </div>
            }
            else if (Model.ReportType == "Revenue")
            {
            <div class="table-responsive">
                <table class="table table-hover align-middle admin-table">
                    <thead>
                        <tr>
                            <th>Reservation ID</th>
                            <th>Guest</th>
                            <th class="text-end">Charges</th>
                            <th class="text-end">Payments</th>
                            <th class="text-end">Balance Due</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Reservations)
                            {
                                var charges = r.TotalCost;
                                var balanceDue = r.BalanceDue;
                                var payments = charges - balanceDue;

                        <tr>
                            <td>@r.ReservationID</td>
                            <td>@r.User?.FirstName @r.User?.LastName</td>
                            <td class="text-end">@charges.ToString("C")</td>
                            <td class="text-end">@payments.ToString("C")</td>
                            <td class="text-end">@balanceDue.ToString("C")</td>
                            <td>@r.ReservationStatus</td>
                        </tr>
                            }
                    </tbody>
                </table>
            </div>
            }
            else if (Model.ReportType == "Occupancy")
            {
            <div class="p-4">
                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <div class="card stat-card h-100">
                            <div class="card-body">
                                <span>Total Sites</span>
                                <strong>@Model.TotalSites</strong>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card stat-card h-100">
                            <div class="card-body">
                                <span>Occupied Sites</span>
                                <strong>@Model.OccupiedSites</strong>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card stat-card h-100">
                            <div class="card-body">
                                <span>Available Sites</span>
                                <strong>@(Model.TotalSites - Model.OccupiedSites)</strong>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card stat-card h-100">
                            <div class="card-body">
                                <span>Occupancy Rate</span>
                                <strong>@Model.OccupancyRate%</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            }
            else if (Model.ReportType == "SiteUsage")
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle admin-table">
                        <thead>
                            <tr>
                                <th>Site Number</th>
                                <th>Site Type</th>
                                <th class="text-end">Reservations</th>
                                <th class="text-end">Reserved Nights</th>
                                <th class="text-end">Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var site in Model.SiteUsageRows)
                            {
                                <tr>
                                    <td>@site.SiteNumber</td>
                                    <td>@site.SiteTypeName</td>
                                    <td class="text-end">@site.ReservationCount</td>
                                    <td class="text-end">@site.ReservedNights</td>
                                    <td class="text-end">@site.RevenueTotal.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
            <div class="table-responsive">
                <table class="table table-hover align-middle admin-table">
                    <thead>
                        <tr>
                            <th>Reservation ID</th>
                            <th>Guest</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Site</th>
                            <th>Check-In</th>
                            <th>Check-Out</th>
                            <th>Status</th>
                            <th class="text-end">Total Cost</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reservation in Model.Reservations)
                            {
                        <tr>
                            <td>@reservation.ReservationID</td>
                            <td>@reservation.User?.FirstName @reservation.User?.LastName</td>
                            <td>@reservation.User?.Email</td>
                            <td>@reservation.User?.PhoneNumber</td>
                            <td>@reservation.Site?.SiteNumber</td>
                            <td>@reservation.CheckInDate.ToShortDateString()</td>
                            <td>@reservation.CheckOutDate.ToShortDateString()</td>
                            <td>@reservation.ReservationStatus</td>
                            <td class="text-end">@reservation.TotalCost.ToString("C")</td>
                        </tr>
                            }
                    </tbody>
                </table>
            </div>
            }
        </div>
    </section>

</div>