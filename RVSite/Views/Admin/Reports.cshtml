@model RVSite.Models.ReportsViewModel

@{
    ViewData["Title"] = "Reports Dashboard";
}

@* Report filter controls *@
<form method="get" asp-controller="Admin" asp-action="Reports" class="border rounded p-4 mb-4">
    <h4 class="text-center mb-4">Filters</h4>

    <div class="row align-items-end">
        <div class="col-md-4">
            <label class="form-label">Start date</label>
            <input type="date" name="startDate" class="form-control" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
        </div>

        <div class="col-md-4">
            <label class="form-label">End date</label>
            <input type="date" name="endDate" class="form-control" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
        </div>

        <div class="col-md-4">
            <button type="submit" class="btn btn-success w-100">
                Generate Report
            </button>
        </div>
    </div>
</form>

@* Report Type Selection *@
<div class="btn-group w-100 mb-4" role="group" aria-label="Report Type">
    <a class="btn btn-outline-secondary" asp-action="Reports" asp-route-reportType="Arrivals">
        Daily Arrivals
    </a>
    <a class="btn btn-outline-secondary" asp-action="Reports" asp-route-reportType="Departures">
        Upcoming Departures
    </a>
    <a class="btn btn-outline-secondary" asp-action="Reports" asp-route-reportType="Occupancy">
        Occupancy
    </a>
    <a class="btn btn-outline-secondary" asp-action="Reports" asp-route-reportType="Reservations">
        Reservation History
    </a>
    <a class="btn btn-outline-secondary" asp-action="Reports" asp-route-reportType="Revenue">
        Revenue / Payments
    </a>
</div>

@* Dashboard Summary cards *@
<div class="border rounded p-4 mb-4">
    <h4 class="text-center mb-4">Report Summary</h4>

    <div class="row text-center">
        <div class="col-md-3 border rounded p-3">
            <h2>@Model.ArrivalsCount</h2>
            <p class="mb-0">Arrivals</p>
        </div>

        <div class="col-md-3 border rounded p-3">
            <h2>@Model.DeparturesCount</h2>
            <p class="mb-0">Departures</p>
        </div>

        <div class="col-md-3 border rounded p-3">
            <h2>@Model.OccupancyRate%</h2>
            <p class="mb-0">Occupancy</p>
        </div>

        <div class="col-md-3 border rounded p-3">
            <h2>@Model.RevenueTotal.ToString("C")</h2>
            <p class="mb-0">Revenue</p>
        </div>
    </div>

    @* Report Results table *@
    <div class="mt-4 p-4 border rounded text-center text-muted">
        <h4 class="mb-3">@Model.ReportType Report Results</h4>
        @* If there are no results, display a message for the user *@
        @if (!Model.Reservations.Any())
        {
            <div class="alert alert-info">
                No reservations were found for the selected date range.
            </div>
        }
        else
        {
            @* Display reservation details in table format for selected report *@
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Reservation ID</th>
                        <th>Guest</th>
                        <th>Site</th>
                        <th>Check-In</th>
                        <th>Check-Out</th>
                        <th>Status</th>
                        <th>Total Cost</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reservation in Model.Reservations)
                    {
                        <tr>
                            <td>@reservation.ReservationID</td>
                            <td>@reservation.User?.FirstName @reservation.User?.LastName</td>
                            <td>@reservation.Site?.SiteNumber</td>
                            <td>@reservation.CheckInDate.ToShortDateString()</td>
                            <td>@reservation.CheckOutDate.ToShortDateString()</td>
                            <td>@reservation.ReservationStatus</td>
                            <td>@reservation.TotalCost.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        
    </div>
</div>
