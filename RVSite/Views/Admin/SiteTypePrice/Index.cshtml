@{
}

@model IEnumerable<RVSite.Models.SiteTypePrice>

<h2>Pricing for @ViewBag.SiteType.Name</h2>

<a asp-action="Create" asp-route-siteTypeId="@ViewBag.SiteType.SiteTypeID" class="btn btn-primary">
    Add Price Range
</a>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Start</th>
            <th>End</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.StartDate.ToShortDateString()</td>
                <td>@(p.EndDate?.ToShortDateString() ?? "Current")</td>
                <td>@p.Price</td>
            </tr>
        }
    </tbody>
</table>