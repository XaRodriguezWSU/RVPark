@model RVSite.Models.User

@{
    ViewData["Title"] = "Edit Employee";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <span class="home-kicker">Administration</span>
        <h1 class="page-title">Edit Employee</h1>
        <p class="page-subtitle">
            Update employee contact information, role assignment, and account lock status.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2 class="h5 mb-0">Employee Information</h2>
    </div>

    <div class="card-body">
        <form asp-action="EditEmployee" asp-route-id="@Model.UserID" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">First Name</label>
                    <input name="firstName" value="@Model.FirstName" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Last Name</label>
                    <input name="lastName" value="@Model.LastName" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input name="email" value="@Model.Email" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Phone Number</label>
                    <input name="phoneNumber" value="@Model.PhoneNumber" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Role</label>
                    <select name="selectedRoleID" class="form-select">
                        @foreach (var role in ViewBag.AvailableRoles)
                        {
                            if (role.RoleID == Model.RoleID)
                            {
                        <option value="@role.RoleID" selected>@role.Type</option>
                            }
                            else
                            {
                        <option value="@role.RoleID">@role.Type</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check account-lock-check">
                        <input name="isLocked"
                               type="checkbox"
                               class="form-check-input"
                               id="isLocked"
                               @(Model.IsLocked ? "checked" : "")
                               value="true" />

                        <label class="form-check-label" for="isLocked">
                            Lock account
                        </label>

                        <input type="hidden" name="isLocked" value="false" />
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    Save Changes
                </button>

                <a asp-action="Employees" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</section>