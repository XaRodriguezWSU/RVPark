@model RVSite.Models.User

<h2>Edit Employee</h2>

<form asp-action="EditEmployee" asp-route-id="@Model.UserID" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">First Name</label>
        <input name="firstName" value="@Model.FirstName" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Last Name</label>
        <input name="lastName" value="@Model.LastName" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input name="email" value="@Model.Email" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Phone Number</label>
        <input name="phoneNumber" value="@Model.PhoneNumber" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Role</label>
        <select name="selectedRoleID" class="form-select">
            @foreach (var role in ViewBag.AvailableRoles)
            {
                if (role.RoleID == Model.RoleID)
                {
            <option value="@role.RoleID" selected>@role.Type</option>
                }
                else
                {
            <option value="@role.RoleID">@role.Type</option>
                }
            }
        </select>
    </div>
    <div class="mb-3 form-check">
        <input name="isLocked" type="checkbox" class="form-check-input"
               @(Model.IsLocked ? "checked" : "") value="true" />
        <label class="form-check-label">Lock account</label>
        @* Hidden field ensures false is sent when checkbox is unchecked *@
        <input type="hidden" name="isLocked" value="false" />
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Employees" class="btn btn-secondary">Cancel</a>
</form>