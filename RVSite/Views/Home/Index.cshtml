@model IEnumerable<RVSite.Models.Site>

    @{
    ViewData["Title"] = "Home";
    var sites = Model?.ToList() ?? new List<RVSite.Models.Site>();
    }

    <section class="home-hero mb-4">
        <div id="homeCarousel" class="carousel slide" data-bs-ride="carousel">
            @if (sites.Any())
        {
            <div class="carousel-indicators">
                @for (int i = 0; i < sites.Count; i++)
                {
                <button type="button"
                        data-bs-target="#homeCarousel"
                        data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")"
                        aria-current="@(i == 0 ? "true" : "false")"
                        aria-label="Slide @(i + 1)">
                </button>
                }
            </div>

            <div class="carousel-inner">
                @for (int i = 0; i < sites.Count; i++)
                {
                    var site = sites[i];
                    var photo = site.Photos?.OrderBy(p => p.SortOrder).FirstOrDefault();

                <div class="carousel-item @(i == 0 ? "active" : "")">
                    @if (photo != null)
                        {
                    <img src="@photo.FilePath"
                         class="d-block w-100 home-hero-img"
                         alt="Site @site.SiteNumber" />
                        }
                        else
                        {
                    <div class="home-hero-placeholder">
                        <span>Site @site.SiteNumber Image Coming Soon</span>
                    </div>
                        }

                    <div class="home-hero-overlay"></div>

                    <div class="carousel-caption home-hero-caption">
                        <span class="home-kicker">Featured Site</span>
                        <h1>Site @site.SiteNumber</h1>
                        <p>
                            @site.SiteType?.Name · @site.MaxRVLength ft max · @site.BaseRate.ToString("C") / night
                        </p>
                    </div>
                </div>
                }
            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#homeCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#homeCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        }
        else
        {
            <div class="home-hero-placeholder">
                <span>Campground Images Coming Soon</span>
            </div>
        }
        </div>
    </section>

    <section class="home-intro card mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <span class="home-kicker">RV Park Reservations</span>
                    <h2 class="page-title">Plan your next stay with RVSite</h2>
                    <p class="lead mb-0">
                        Browse available RV sites, compare rates and site details, and begin a reservation from one clean overview.
                    </p>
                </div>

                <div class="col-lg-4">
                    <div class="home-summary-box">
                        <span class="text-muted">Available Sites</span>
                        <strong>@sites.Count</strong>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="card site-list-card">
        <div class="card-header section-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-0">Available RV Sites</h2>
                <p class="mb-0 text-muted">Review current site options and nightly rates.</p>
            </div>
        </div>

        <div class="card-body p-0">
            @if (!sites.Any())
        {
            <div class="p-4">
                <div class="alert alert-info mb-0">
                    No RV sites are currently available.
                </div>
            </div>
        }
        else
        {
            <div class="site-list">
                @foreach (var site in sites)
                {
                    var photo = site.Photos?.OrderBy(p => p.SortOrder).FirstOrDefault();

                <article class="site-row">
                    <div class="site-row-image">
                        @if (photo != null)
                            {
                        <img src="@photo.FilePath"
                             alt="Site @site.SiteNumber" />
                            }
                            else
                            {
                        <div class="site-image-placeholder">
                            Image
                        </div>
                            }
                    </div>

                    <div class="site-row-main">
                        <div>
                            <span class="site-type">@site.SiteType?.Name</span>
                            <h3>Site @site.SiteNumber</h3>
                        </div>

                        <div class="site-meta">
                            <span>@site.MaxRVLength ft max</span>
                            <span>@site.BaseRate.ToString("C") / night</span>
                        </div>
                    </div>

                    <div class="site-row-action">
                        <a asp-controller="Reservation"
                           asp-action="Create"
                           asp-route-siteId="@site.SiteID"
                           class="btn btn-primary">
                            Reserve
                        </a>
                    </div>
                </article>
                }
            </div>
        }
        </div>
    </section>
