@model RVSite.Models.Reservation

@{
    ViewData["Title"] = "Checkout";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <span class="home-kicker">Complete Your Booking</span>
        <h1 class="page-title">Checkout</h1>
        <p class="page-subtitle">
            Review your reservation total and choose how you'd like to pay.
        </p>
    </div>
</section>

@if (TempData["Error"] != null)
{
<div class="alert alert-danger">@TempData["Error"]</div>
}

<section class="card mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">Reservation Summary</h2>
    </div>

    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Reservation Number</span>
                    <strong>#@Model.ReservationID</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Site</span>
                    <strong>Site @Model.Site?.SiteNumber</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Check-In</span>
                    <strong>@Model.CheckInDate.ToShortDateString()</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Check-Out</span>
                    <strong>@Model.CheckOutDate.ToShortDateString()</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Total Cost</span>
                    <strong>@Model.TotalCost.ToString("C")</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Amount Due</span>
                    <strong>@(((decimal)ViewBag.AmountDue).ToString("C"))</strong>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="card mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">Pay Online</h2>
    </div>

    <div class="card-body">
        <p class="text-muted">You'll be redirected to Stripe to securely complete your payment.</p>

        <form asp-controller="Payment" asp-action="ProcessStripePayment" method="post">
            <input type="hidden" name="reservationId" value="@Model.ReservationID" />
            <button type="submit" class="btn btn-primary">
                Pay @(((decimal)ViewBag.AmountDue).ToString("C")) with Card
            </button>
        </form>
    </div>
</section>
