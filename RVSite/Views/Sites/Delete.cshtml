@model RVSite.Models.Site

@{
    ViewData["Title"] = "Delete Site";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <span class="home-kicker">Site Management</span>
        <h1 class="page-title">Delete Site @Model.SiteNumber</h1>
        <p class="page-subtitle">Confirm before removing this site record.</p>
    </div>
</section>

<section class="card border-danger">
    <div class="card-header bg-danger text-white">
        <h2 class="h5 mb-0">Confirm Delete</h2>
    </div>

    <div class="card-body">
        <div class="alert alert-warning">
            Are you sure you want to delete this site? This action cannot be undone.
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Site Number</span>
                    <strong>@Model.SiteNumber</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Site Type</span>
                    <strong>@Model.SiteType?.Name</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Status</span>
                    <strong>@Model.SiteStatus</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Max RV Length</span>
                    <strong>@Model.MaxRVLength ft</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Base Rate</span>
                    <strong>@Model.BaseRate.ToString("C")</strong>
                </div>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="SiteID" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete Site</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</section>