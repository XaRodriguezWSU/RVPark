@model RVSite.Models.Site

@{
    ViewData["Title"] = "Site Details";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <span class="home-kicker">Site Management</span>
        <h1 class="page-title">Site @Model.SiteNumber</h1>
        <p class="page-subtitle">Review site configuration and operating details.</p>
    </div>
</section>

<section class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">Site Details</h2>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.SiteID" class="btn btn-sm btn-primary">Edit</a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to Sites</a>
        </div>
    </div>

    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Site Number</span>
                    <strong>@Model.SiteNumber</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Site Type</span>
                    <strong>@Model.SiteType?.Name</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Status</span>
                    <strong>@Model.SiteStatus</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Max RV Length</span>
                    <strong>@Model.MaxRVLength ft</strong>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="detail-box">
                    <span>Base Rate</span>
                    <strong>@Model.BaseRate.ToString("C")</strong>
                </div>
            </div>
        </div>
    </div>
</section>