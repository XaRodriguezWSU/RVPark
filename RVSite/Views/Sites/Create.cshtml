@model RVSite.Models.Site

@{
    ViewData["Title"] = "Create Site";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <span class="home-kicker">Site Management</span>
        <h1 class="page-title">Create Site</h1>
        <p class="page-subtitle">Add a new RV park site record.</p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2 class="h5 mb-0">Site Details</h2>
    </div>

    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="SiteNumber" class="form-label"></label>
                    <input asp-for="SiteNumber" class="form-control" />
                    <span asp-validation-for="SiteNumber" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SiteTypeID" class="form-label"></label>
                    <select asp-for="SiteTypeID"
                            class="form-select"
                            asp-items="@(new SelectList(ViewBag.SiteTypes, "SiteTypeID", "Name"))">
                        <option value="">-- Select Site Type --</option>
                    </select>
                    <span asp-validation-for="SiteTypeID" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SiteStatus" class="form-label"></label>
                    <input asp-for="SiteStatus" class="form-control" />
                    <span asp-validation-for="SiteStatus" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MaxRVLength" class="form-label"></label>
                    <input asp-for="MaxRVLength" class="form-control" />
                    <span asp-validation-for="MaxRVLength" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="BaseRate" class="form-label"></label>
                    <input asp-for="BaseRate" class="form-control" />
                    <span asp-validation-for="BaseRate" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Create Site</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Back to Sites</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}