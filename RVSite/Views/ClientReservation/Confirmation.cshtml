@model RVSite.Models.Reservation

@{
    ViewData["Title"] = "Reservation Confirmed";
}

<div class="row justify-content-center py-4">
    <div class="col-xl-9">
        <section class="card">
            <div class="card-body p-4 p-lg-5">
                <div class="text-center mb-4">
                    <div class="confirmation-mark mb-3">✓</div>

                    <span class="home-kicker">Booking Complete</span>

                    <h1 class="page-title">Reservation Confirmed</h1>

                    <p class="page-subtitle">
                        Your stay has been successfully reserved.
                        Keep reservation #@Model.ReservationID for your records.
                    </p>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6 col-xl-4">
                        <div class="detail-box">
                            <span>Reservation Number</span>
                            <strong>#@Model.ReservationID</strong>
                        </div>
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <div class="detail-box">
                            <span>Guest</span>
                            <strong>
                                @Model.User?.FirstName @Model.User?.LastName
                            </strong>
                        </div>
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <div class="detail-box">
                            <span>Site</span>
                            <strong>
                                Site @Model.Site?.SiteNumber
                            </strong>
                        </div>
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <div class="detail-box">
                            <span>Site Type</span>
                            <strong>@Model.Site?.SiteType?.Name</strong>
                        </div>
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <div class="detail-box">
                            <span>Check-In</span>
                            <strong>@Model.CheckInDate.ToShortDateString()</strong>
                        </div>
                    </div>

                    <div class="col-md-6 col-xl-4">
                        <div class="detail-box">
                            <span>Check-Out</span>
                            <strong>@Model.CheckOutDate.ToShortDateString()</strong>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="detail-box">
                            <span>Adults</span>
                            <strong>@Model.NumberOfAdults</strong>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="detail-box">
                            <span>Children</span>
                            <strong>@Model.NumberOfChildren</strong>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="detail-box">
                            <span>Pets</span>
                            <strong>@Model.NumberOfPets</strong>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="detail-box">
                            <span>Total Cost</span>
                            <strong>@Model.TotalCost.ToString("C")</strong>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="detail-box">
                            <span>Balance Due</span>
                            <strong>@Model.BalanceDue.ToString("C")</strong>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.SpecialRequests))
                {
                <div class="card bg-light shadow-none mb-4">
                    <div class="card-body">
                        <h2 class="h6 fw-bold">Special Requests</h2>
                        <p class="mb-0">@Model.SpecialRequests</p>
                    </div>
                </div>
                }

                <div class="d-flex flex-wrap justify-content-center gap-2">
                    <a asp-controller="ClientReservation"
                       asp-action="MyReservations"
                       class="btn btn-primary">
                        View My Reservations
                    </a>

                    <a asp-controller="ClientReservation"
                       asp-action="Book"
                       class="btn btn-outline-secondary">
                        Make Another Reservation
                    </a>
                </div>
            </div>
        </section>
    </div>
</div>