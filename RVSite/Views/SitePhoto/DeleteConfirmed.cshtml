@model RVSite.Models.SitePhoto

@{
    ViewData["Title"] = "Photo Deleted";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <span class="home-kicker">Media Management</span>
        <h1 class="page-title">Photo Deleted</h1>
        <p class="page-subtitle">
            The selected photo was removed successfully.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-body p-4">
        <div class="alert alert-success mb-4">
            The photo has been successfully deleted.
        </div>

        <a class="btn btn-primary"
           asp-action="Index"
           asp-route-id="@Model.SiteID">
            Back to Photos
        </a>
    </div>
</section>