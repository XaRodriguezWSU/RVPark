@model RVSite.Models.SitePhoto

@{
    ViewData["Title"] = "Edit Site Photo";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <span class="home-kicker">Media Management</span>
        <h1 class="page-title">Edit Site Photo</h1>
        <p class="page-subtitle">
            Update the caption and display order for this uploaded photo.
        </p>
    </div>
</section>

<section class="row g-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">
                <h2 class="h5 mb-0">Current Photo</h2>
            </div>

            <div class="card-body">
                <img src="@Model.FilePath"
                     class="photo-preview-large"
                     alt="@Model.Caption" />
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <h2 class="h5 mb-0">Photo Details</h2>
            </div>

            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="SitePhotoID" />
                    <input type="hidden" asp-for="SiteID" />
                    <input type="hidden" asp-for="FilePath" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Caption" class="form-label"></label>
                        <input asp-for="Caption" class="form-control" />
                        <span asp-validation-for="Caption" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SortOrder" class="form-label"></label>
                        <input asp-for="SortOrder" class="form-control" />
                        <span asp-validation-for="SortOrder" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            Save Changes
                        </button>

                        <a asp-controller="SitePhoto"
                           asp-action="Index"
                           asp-route-id="@Model.SiteID"
                           class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>