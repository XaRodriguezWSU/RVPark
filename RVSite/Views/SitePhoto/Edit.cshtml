@{
}


@model RVSite.Models.SitePhoto

<h2>Edit Photo</h2>

<img src="@Model.FilePath" class="img-fluid mb-3" />

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="SitePhotoID" />
    <input type="hidden" asp-for="SiteID" />
    <input type="hidden" asp-for="FilePath" />

    <div class="form-group">
        <label asp-for="Caption"></label>
        <input asp-for="Caption" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="SortOrder"></label>
        <input asp-for="SortOrder" class="form-control" />
    </div>

    <button class="btn btn-primary">Save</button>
</form>
