@model RVSite.Models.SitePhoto

@{
    ViewData["Title"] = "Add Site Photo";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <span class="home-kicker">Media Management</span>
        <h1 class="page-title">Add Site Photo</h1>
        <p class="page-subtitle">
            Upload a new image, caption, and display order for this site.
        </p>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2 class="h5 mb-0">Photo Details</h2>
    </div>

    <div class="card-body">
        <form asp-action="Create"
              asp-route-id="@Model.SiteID"
              method="post"
              enctype="multipart/form-data">

            <input type="hidden" asp-for="SiteID" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-lg-8">
                    <label class="form-label">Photo File</label>
                    <input type="file"
                           name="file"
                           class="form-control form-control-lg"
                           accept="image/*" />
                </div>

                <div class="col-lg-4">
                    <label asp-for="SortOrder" class="form-label"></label>
                    <input asp-for="SortOrder" class="form-control form-control-lg" />
                    <span asp-validation-for="SortOrder" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Caption" class="form-label"></label>
                    <input asp-for="Caption"
                           class="form-control"
                           placeholder="Example: Pull-through RV site near trees" />
                    <span asp-validation-for="Caption" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    Upload Photo
                </button>

                <a asp-controller="SitePhoto"
                   asp-action="Index"
                   asp-route-id="@Model.SiteID"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</section>