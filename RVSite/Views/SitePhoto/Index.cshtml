@model RVSite.Models.Site

@{
    ViewData["Title"] = $"Photos for Site {Model.SiteNumber}";
    var photos = Model.Photos?.OrderBy(p => p.SortOrder).ToList() ?? new List<RVSite.Models.SitePhoto>();
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <span class="home-kicker">Media Management</span>
                <h1 class="page-title">Site @Model.SiteNumber Photos</h1>
                <p class="page-subtitle">
                    Manage captions, sort order, and uploaded photos for this site.
                </p>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-2">
                <a asp-controller="SitePhoto"
                   asp-action="Create"
                   asp-route-id="@Model.SiteID"
                   class="btn btn-primary">
                    Add Photo
                </a>

                <a asp-controller="SitePhoto"
                   asp-action="Manage"
                   class="btn btn-outline-secondary">
                    All Site Photos
                </a>
            </div>
        </div>
    </div>
</section>

@if (!photos.Any())
{
<section class="card">
    <div class="card-body p-4 text-center">
        <h2 class="h5 mb-2">No photos uploaded yet</h2>
        <p class="text-muted mb-3">
            Add the first image for Site @Model.SiteNumber.
        </p>

        <a asp-controller="SitePhoto"
           asp-action="Create"
           asp-route-id="@Model.SiteID"
           class="btn btn-primary">
            Upload Photo
        </a>
    </div>
</section>
}
else
{
<section class="row g-4">
    @foreach (var p in photos)
        {
    <div class="col-md-6 col-xl-4">
        <article class="card h-100 photo-gallery-card">

            <img src="@p.FilePath"
                 class="card-img-top photo-gallery-img"
                 alt="@p.Caption" />

            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <h2 class="h5 fw-bold mb-0">
                        @(string.IsNullOrWhiteSpace(p.Caption) ? "Untitled Photo" : p.Caption)
                    </h2>

                    <span class="badge bg-secondary">
                        Order @p.SortOrder
                    </span>
                </div>

                <p class="text-muted mb-3">
                    Uploaded @p.UploadedAt.ToShortDateString()
                </p>

                <div class="d-flex gap-2">
                    <a asp-controller="SitePhoto"
                       asp-action="Edit"
                       asp-route-id="@p.SitePhotoID"
                       class="btn btn-sm btn-outline-primary">
                        Edit
                    </a>

                    <a asp-controller="SitePhoto"
                       asp-action="Delete"
                       asp-route-id="@p.SitePhotoID"
                       class="btn btn-sm btn-outline-danger">
                        Delete
                    </a>
                </div>
            </div>

        </article>
    </div>
        }
</section>
}