<header>
    <nav class="navbar navbar-expand-lg navbar-light border rounded shadow-sm"
         style="background-color:#b8d0c5;">
        <div class="container-fluid">

            <!-- Logo -->
            <a class="navbar-brand px-4 py-2"
               asp-controller="Home"
               asp-action="Index">
                RvSite
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navigation -->
            <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">

                <ul class="navbar-nav mb-2 mb-lg-0">

                    @if (!(User.Identity?.IsAuthenticated ?? false))
                    {
                    <li class="nav-item">
                        <a class="nav-link fs-4"
                           asp-controller="Home"
                           asp-action="Index">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fs-4"
                           asp-controller="Sites"
                           asp-action="Index">
                            RV Sites
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fs-4"
                           asp-controller="Account"
                           asp-action="Login">
                            Log In
                        </a>
                    </li>
                    }
                    else if (User.IsInRole("Employee"))
                    {
                    <li class="nav-item">
                        <a class="nav-link fs-4"
                           asp-controller="Tasks"
                           asp-action="Index">
                            Tasks
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fs-4"
                           asp-controller="Arrivals"
                           asp-action="Index">
                            Arrivals
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fs-4"
                           asp-controller="Dashboard"
                           asp-action="Index">
                            Dashboard
                        </a>
                    </li>
                    }
                    else
                    {
                    <li class="nav-item">
                        <a class="nav-link fs-4"
                           asp-controller="Home"
                           asp-action="Index">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fs-4"
                           asp-controller="Sites"
                           asp-action="Index">
                            RV Sites
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fs-4"
                           asp-controller="Account"
                           asp-action="Index">
                            Account
                        </a>
                    </li>
                    }

                </ul>

            </div>

        </div>
    </nav>
</header>