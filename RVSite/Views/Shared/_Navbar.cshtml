<header class="app-header">
    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="app-container d-flex align-items-center">

            <a class="navbar-brand app-brand"
               asp-controller="Home"
               asp-action="Index">
                RVSite
            </a>

            <button class="navbar-toggler ms-auto"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">
                <ul class="navbar-nav align-items-lg-center gap-lg-2">

                    <li class="nav-item">
                        <a class="nav-link app-nav-link"
                           asp-controller="Home"
                           asp-action="Index">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link app-nav-link"
                           asp-controller="Sites"
                           asp-action="Index">
                            RV Sites
                        </a>
                    </li>

                    @if (User.Identity?.IsAuthenticated ?? false)
    {
                    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
                    <li class="nav-item">
                        <a class="nav-link app-nav-link"
                           asp-controller="Admin"
                           asp-action="Dashboard">
                            Dashboard
                        </a>
                    </li>
        }

                    <li class="nav-item ms-lg-3 d-flex align-items-center">
                        <span class="text-muted me-3">
                            Hello, @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                        </span>

                        <form asp-controller="Login"
                              asp-action="Logout"
                              method="post"
                              class="d-inline">

                            @Html.AntiForgeryToken()

                            <button type="submit"
                                    class="btn rounded-pill px-4">
                                Log Out
                            </button>

                        </form>
                    </li>
    }
    else
    {
                    <li class="nav-item ms-lg-3">
                        <a asp-controller="Login"
                           asp-action="Index"
                           class="btn btn-primary rounded-pill px-4">
                            Sign In
                        </a>
                    </li>
    }

                </ul>
            </div>

        </div>
    </nav>
</header>