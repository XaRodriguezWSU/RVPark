@model RVSite.Models.Fee

@{
    ViewData["Title"] = "Create Fee";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-5">

        <span class="home-kicker">Administration</span>

        <h1 class="page-title">Create Fee</h1>

        <p class="page-subtitle">
            Add a new fee to a reservation.
        </p>

    </div>
</section>

<section class="card">

    <div class="card-header">
        <h2 class="h5 mb-0">Fee Information</h2>
    </div>

    <div class="card-body">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3"></div>

            <div class="row g-3">

                <div class="col-md-6">
                    <label asp-for="ReservationID" class="form-label"></label>

                    <select asp-for="ReservationID"
                            asp-items="ViewBag.ReservationID"
                            class="form-select">

                        <option value="">Select Reservation</option>

                    </select>
                </div>

                <div class="col-md-6">

                    <label asp-for="NameCode" class="form-label"></label>

                    <select asp-for="NameCode"
                            asp-items="Html.GetEnumSelectList<RVSite.Models.FeeCodes>()"
                            class="form-select"></select>

                </div>

                <div class="col-md-6">

                    <label asp-for="Amount" class="form-label"></label>

                    <input asp-for="Amount"
                           class="form-control" />

                    <small class="text-muted">
                        For cancellation fees, enter the daily charge amount. For other fees, enter the one-time fee amount.
                    </small>

                </div>

                <div class="col-md-6">

                    <label asp-for="EffectiveDate" class="form-label"></label>

                    <input asp-for="EffectiveDate"
                           type="date"
                           class="form-control" />

                </div>

            </div>

            <div class="mt-4">

                <button class="btn btn-primary">
                    Create Fee
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</section>