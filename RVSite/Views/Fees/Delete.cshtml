@model RVSite.Models.Fee

@{
    ViewData["Title"] = "Delete Fee";
}

<h1>Delete Fee</h1>

<h3>Are you sure you want to delete this fee?</h3>

<div>
    <h4>Fee</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            Reservation
        </dt>
        <dd class="col-sm-10">
            Reservation #@Model.ReservationID
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.NameCode)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.NameCode)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Amount)
        </dt>
        <dd class="col-sm-10">
            @Model.Amount.ToString("C")
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EffectiveDate)
        </dt>
        <dd class="col-sm-10">
            @Model.EffectiveDate.ToShortDateString()
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="FeeID" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
