@model RVSite.Models.Fee

@{
    ViewData["Title"] = "Delete Fee";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">

        <span class="home-kicker">Administration</span>

        <h1 class="page-title">Delete Fee</h1>

        <p class="page-subtitle">
            Review this fee before permanently deleting it.
        </p>

    </div>
</section>

<section class="card shadow-sm">

    <div class="card-body p-4">

        <div class="alert alert-warning mb-4">

            <strong>Warning:</strong> This action cannot be undone.

        </div>

        <div class="row g-3 mb-4">

            <div class="col-md-6">

                <div class="detail-box">

                    <span>Reservation</span>

                    <strong>Reservation #@Model.ReservationID</strong>

                </div>

            </div>

            <div class="col-md-6">

                <div class="detail-box">

                    <span>Fee Type</span>

                    <strong>@Model.NameCode</strong>

                </div>

            </div>

            <div class="col-md-6">

                <div class="detail-box">

                    <span>Amount</span>

                    <strong>@Model.Amount.ToString("C")</strong>

                </div>

            </div>

            <div class="col-md-6">

                <div class="detail-box">

                    <span>Effective Date</span>

                    <strong>@Model.EffectiveDate.ToShortDateString()</strong>

                </div>

            </div>

        </div>

        <form asp-action="Delete">

            <input type="hidden" asp-for="FeeID" />

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-danger">
                    Delete Fee
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</section>