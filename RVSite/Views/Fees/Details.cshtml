@model RVSite.Models.Fee

<section class="card admin-hero mb-4">
    <div class="card-body p-5">

        <span class="home-kicker">Administration</span>

        <h1 class="page-title">Fee Details</h1>

        <p class="page-subtitle">
            Review fee information.
        </p>

    </div>
</section>

<section class="card">

    <div class="card-body">

        <div class="row g-3">

            <div class="col-md-6">

                <div class="detail-box">

                    <span>Reservation</span>

                    <strong>Reservation #@Model.ReservationID</strong>

                </div>

            </div>

            <div class="col-md-6">

                <div class="detail-box">

                    <span>Fee Type</span>

                    <strong>@Model.NameCode</strong>

                </div>

            </div>

            <div class="col-md-6">

                <div class="detail-box">

                    <span>Amount</span>

                    <strong>@Model.Amount.ToString("C")</strong>

                </div>

            </div>

            <div class="col-md-6">

                <div class="detail-box">

                    <span>Effective Date</span>

                    <strong>@Model.EffectiveDate.ToShortDateString()</strong>

                </div>

            </div>

        </div>

        <div class="mt-4">

            <a asp-action="Edit"
               asp-route-id="@Model.FeeID"
               class="btn btn-primary">
                Edit
            </a>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>

        </div>

    </div>

</section>