@model RVSite.Models.Fee

@{
    ViewData["Title"] = "Edit Fee";
}

<section class="card admin-hero mb-4">
    <div class="card-body p-4 p-lg-5">

        <span class="home-kicker">Administration</span>

        <h1 class="page-title">Edit Fee</h1>

        <p class="page-subtitle">
            Update an existing reservation fee.
        </p>

    </div>
</section>

<section class="card shadow-sm">

    <div class="card-header">
        <h2 class="h5 mb-0">Fee Information</h2>
    </div>

    <div class="card-body">

        <form asp-action="Edit">

            <input type="hidden" asp-for="FeeID" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3"></div>

            <div class="row g-3">

                <div class="col-md-6">

                    <label asp-for="ReservationID" class="form-label"></label>

                    <select asp-for="ReservationID"
                            asp-items="ViewBag.ReservationID"
                            class="form-select">
                    </select>

                    <span asp-validation-for="ReservationID" class="text-danger"></span>

                </div>

                <div class="col-md-6">

                    <label asp-for="NameCode" class="form-label"></label>

                    <select asp-for="NameCode"
                            asp-items="Html.GetEnumSelectList<RVSite.Models.FeeCodes>()"
                            class="form-select">
                    </select>

                    <span asp-validation-for="NameCode" class="text-danger"></span>

                </div>

                <div class="col-md-6">

                    <label asp-for="Amount" class="form-label"></label>

                    <input asp-for="Amount"
                           class="form-control" />

                    <span asp-validation-for="Amount" class="text-danger"></span>

                </div>

                <div class="col-md-6">

                    <label asp-for="EffectiveDate" class="form-label"></label>

                    <input asp-for="EffectiveDate"
                           type="date"
                           class="form-control" />

                    <span asp-validation-for="EffectiveDate" class="text-danger"></span>

                </div>

            </div>

            <div class="mt-4 d-flex gap-2">

                <button type="submit"
                        class="btn btn-primary">
                    Save Changes
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}